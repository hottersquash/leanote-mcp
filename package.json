{
  "name": "leanote-mcp",
  "version": "1.0.0",
  "description": "MCP server for Cursor to interact with self-hosted Leanote",
  "type": "module",
  "main": "dist/http.js",
  "bin": {
    "leanote-mcp": "dist/http.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/http.js",
    "dev": "tsx src/http.ts",
    "deploy:docker": "bash deploy-docker.sh",
    "deploy:npm": "bash deploy-npm.sh"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "leanote",
    "cursor"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "express": "^4.21.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
